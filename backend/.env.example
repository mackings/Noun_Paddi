# Server Configuration
PORT=5001
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=your_mongodb_connection_string

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Gemini API (Tier 1 - Paid recommended for production)
# Used for: Summary generation, Question generation, Plagiarism detection
# Tier 1 limits: 300 RPM, 2M TPM, 1500 RPD
GEMINI_API_KEY=your_gemini_api_key

# Flutterwave (Consultation payments)
FLW_PUBLIC_KEY=your_flutterwave_public_key
FLW_SECRET_KEY=your_flutterwave_secret_key
FLW_WEBHOOK_HASH=your_flutterwave_webhook_hash

# CORS Origin (Frontend URL)
# For local development
# FRONTEND_URL=http://localhost:3000
# For production (update with your Vercel frontend URL)
# FRONTEND_URL=https://your-frontend-app.vercel.app
# CORS_ORIGINS=https://nounpaddi.vercel.app,https://www.nounpaddi.vercel.app
# ALLOW_VERCEL_PREVIEWS=false

# Share link expiration (days)
# SHARE_LINK_TTL_DAYS=30

# SMTP (Email - Gmail or any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=NounPaddi

# Optional Mailjet fallback
# MAILJET_API_KEY=your_mailjet_api_key
# MAILJET_API_SECRET=your_mailjet_api_secret
# MAILJET_FROM_EMAIL=your_verified_mailjet_sender@example.com
# MAILJET_FROM_NAME=NounPaddi

# Scheduled broadcast cron auth (recommended for Vercel Cron)
# If using Vercel Cron, set CRON_SECRET in Vercel project settings.
# Optional override:
# BROADCAST_CRON_SECRET=your_random_long_secret
